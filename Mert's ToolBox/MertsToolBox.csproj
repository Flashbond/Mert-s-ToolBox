	</ItemGroup>

	<ItemGroup>
		<None Include="$(ModPropsFile)" Link="Properties\Mod.props" />
		<None Remove="C:\Users\Mert\AppData\LocalLow\Colossal Order\Cities Skylines II\.cache\Modding\Mod.targets" />
		<None Include="$(ModTargetsFile)" Link="Properties\Mod.targets" />
	</ItemGroup>

	<ItemGroup>
		<Compile Update="Mert's ToolBox\Properties\Settings.Designer.cs">
			<DesignTimeSharedInput>True</DesignTimeSharedInput>
			<AutoGen>True</AutoGen>
			<DependentUpon>Settings.settings</DependentUpon>
		</Compile>
	</ItemGroup>

	<ItemGroup>
		<None Update="Mert's ToolBox\Properties\Settings.settings">
			<Generator>SettingsSingleFileGenerator</Generator>
			<LastGenOutput>Settings.Designer.cs</LastGenOutput>
		</None>
	</ItemGroup>

	<!-- 1) Build frontend before C# build -->
	<Target Name="BuildFrontendForDeploy" AfterTargets="RunModPostProcessor" BeforeTargets="DeployWIP">
		<Message Text="Running frontend build (npm run build)..." Importance="high" />
		<Exec Command="npm run build" WorkingDirectory="$(MSBuildProjectDirectory)\UX" />
	</Target>

	<!-- 2) Copy frontend root files (.mjs / .css) from ui-dist to OutDir -->
	<Target Name="CopyFrontendRootToOutDir" BeforeTargets="DeployWIP" Condition="Exists('UX\ui-dist')">
		<ItemGroup>
			<FrontendRootFiles Include="UX\ui-dist\*.mjs" />
			<FrontendRootFiles Include="UX\ui-dist\*.css" />
		</ItemGroup>

		<Message Text="Copying frontend root files to $(OutDir)" Importance="high" />
		<Copy SourceFiles="@(FrontendRootFiles)" DestinationFiles="@(FrontendRootFiles->'$(OutDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
	</Target>

	<!-- 3) Copy generated images folder (svg/png/etc) from ui-dist to OutDir -->
	<Target Name="CopyFrontendImagesToOutDir" BeforeTargets="DeployWIP" Condition="Exists('UX\ui-dist\icons')">
		<ItemGroup>
			<FrontendImages Include="UX\ui-dist\icons\**\*.*" />
		</ItemGroup>
		<Message Text="Copying frontend icons to $(OutDir)\icons" Importance="high" />
		<Copy SourceFiles="@(FrontendImages)" DestinationFiles="@(FrontendImages->'$(OutDir)icons\%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
	</Target>

</Project>