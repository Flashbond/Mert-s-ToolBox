	  <None Remove="bin\**" />
	  <None Remove="Mert%27s ToolBox\**" />
	  <None Remove="ui-dist\**" />
	  <UpToDateCheckInput Remove="bin\**" />
	  <UpToDateCheckInput Remove="Mert%27s ToolBox\**" />
	  <UpToDateCheckInput Remove="ui-dist\**" />
	</ItemGroup>
	
